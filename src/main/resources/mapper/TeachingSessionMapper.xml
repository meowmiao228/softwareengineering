<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.aicao.teaching.mapper.TeachingSessionMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO teaching_session (title, subject_code)
        VALUES (#{title}, #{subjectCode})
    </insert>

    <select id="selectById" resultType="org.example.aicao.teaching.domain.TeachingSession">
        SELECT id, title, subject_code AS subjectCode, created_at AS createdAt
        FROM teaching_session
        WHERE id = #{id}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM teaching_session
    </select>

    <select id="selectPage" resultType="org.example.aicao.teaching.domain.TeachingSession">
        SELECT id, title, subject_code AS subjectCode, created_at AS createdAt
        FROM teaching_session
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>
</mapper>
